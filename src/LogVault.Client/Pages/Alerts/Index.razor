@page "/alerts"
@inject ILogVaultApiClient Api
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Alert Rules — LogVault</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:700">Alert Rules</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Email notifications when log events match your criteria</MudText>
    </div>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/alerts/new">
        New Rule
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

<MudPaper Elevation="2" Style="border-radius:12px; overflow:hidden">
    <MudTable T="AlertRuleDto"
              Items="@(_rules ?? new())"
              Dense="true"
              Hover="true"
              Elevation="0"
              Loading="@_loading"
              Style="background:transparent">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Level</MudTh>
            <MudTh>Expression</MudTh>
            <MudTh>Throttle</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Last Fired</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-weight:500">@context.Name</MudText>
            </MudTd>
            <MudTd><LogLevelChip Level="@context.MinimumLevel" /></MudTd>
            <MudTd>
                <MudTooltip Text="@context.FilterExpression" Placement="Placement.Top">
                    <MudText Typo="Typo.body2" Style="font-family:monospace; font-size:0.75rem; cursor:default">
                        @Truncate(context.FilterExpression, 40)
                    </MudText>
                </MudTooltip>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@context.ThrottleMinutes min</MudText>
            </MudTd>
            <MudTd>
                @if (context.IsEnabled)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Enabled</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Filled">Disabled</MudChip>
                }
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                    @(context.LastFiredAt?.ToLocalTime().ToString("MM/dd HH:mm") ?? "Never")
                </MudText>
            </MudTd>
            <MudTd Style="text-align:right">
                <MudTooltip Text="Edit">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   Href="@($"/alerts/{context.Id}")" />
                </MudTooltip>
                <MudTooltip Text="Delete">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="() => ConfirmDelete(context)" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="pa-6 d-flex flex-column align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsOff" Style="font-size:3rem; opacity:0.3" Class="mb-2" />
                <MudText Typo="Typo.body1">No alert rules yet</MudText>
                <MudText Typo="Typo.body2">Create your first rule to get notified about critical events.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<AlertRuleDto>? _rules;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _rules = await Api.GetAlertsAsync();
        _loading = false;
    }

    private async Task ConfirmDelete(AlertRuleDto rule)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, "Delete Alert Rule" },
            { x => x.Message, $"Delete \"{rule.Name}\"? This action cannot be undone." },
            { x => x.ConfirmText, "Delete" }
        };
        var result = await DialogService.ShowAsync<ConfirmDialog>("Confirm", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        var dialogResult = await result.Result;
        if (!dialogResult.Canceled)
        {
            await Api.DeleteAlertAsync(rule.Id);
            _rules = await Api.GetAlertsAsync();
            Snackbar.Add($"Alert rule \"{rule.Name}\" deleted.", Severity.Success);
        }
    }

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";
}
