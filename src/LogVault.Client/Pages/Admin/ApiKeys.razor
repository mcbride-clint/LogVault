@page "/admin/apikeys"
@inject ILogVaultApiClient Api
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>API Keys — LogVault</PageTitle>

<div class="d-flex justify-space-between align-center mb-6">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:700">API Keys</MudText>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">Manage keys for log ingestion</MudText>
    </div>
</div>

@* Create new key form *@
<MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius:12px">
    <MudText Typo="Typo.subtitle1" Class="mb-3">Create New Key</MudText>
    <MudGrid Spacing="2" AlignItems="Center">
        <MudItem xs="12" sm="5">
            <MudTextField @bind-Value="_newLabel"
                          Label="Label"
                          Variant="Variant.Outlined"
                          Dense="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Label"
                          Placeholder="e.g. Production API" />
        </MudItem>
        <MudItem xs="12" sm="5">
            <MudTextField @bind-Value="_newApp"
                          Label="Default Application (optional)"
                          Variant="Variant.Outlined"
                          Dense="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Apps"
                          Placeholder="e.g. MyService" />
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="CreateKey"
                       Disabled="@string.IsNullOrWhiteSpace(_newLabel)">
                Create
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@* Keys table *@
<MudPaper Elevation="2" Style="border-radius:12px; overflow:hidden">
    <MudTable T="ApiKeyDto"
              Items="@(_keys ?? new())"
              Dense="true"
              Hover="true"
              Elevation="0"
              Loading="@_loading"
              Style="background:transparent">
        <HeaderContent>
            <MudTh>Label</MudTh>
            <MudTh>Application</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Status</MudTh>
            <MudTh Style="text-align:right">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-weight:500">@context.Label</MudText>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2">@(context.DefaultApplication ?? "—")</MudText>
            </MudTd>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-size:0.8rem">
                    @context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                </MudText>
            </MudTd>
            <MudTd>
                @if (context.IsRevoked)
                {
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">Revoked</MudChip>
                }
                else if (context.ExpiresAt.HasValue)
                {
                    <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                             Icon="@Icons.Material.Filled.Schedule">
                        Expiring @context.ExpiresAt.Value.ToLocalTime().ToString("MM/dd HH:mm")
                    </MudChip>
                }
                else if (context.IsEnabled)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">Disabled</MudChip>
                }
            </MudTd>
            <MudTd Style="text-align:right">
                @if (!context.IsRevoked)
                {
                    <MudTooltip Text="Rotate key">
                        <MudIconButton Icon="@Icons.Material.Filled.Autorenew"
                                       Color="Color.Warning"
                                       Size="Size.Small"
                                       OnClick="() => Rotate(context.Id)" />
                    </MudTooltip>
                    <MudTooltip Text="Revoke key">
                        <MudIconButton Icon="@Icons.Material.Filled.Block"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="() => ConfirmRevoke(context)" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="pa-6 d-flex flex-column align-center mud-text-secondary">
                <MudIcon Icon="@Icons.Material.Filled.VpnKeyOff" Style="font-size:3rem; opacity:0.3" Class="mb-2" />
                <MudText Typo="Typo.body1">No API keys yet</MudText>
                <MudText Typo="Typo.body2">Create a key to start ingesting logs.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private List<ApiKeyDto>? _keys;
    private string _newLabel = "";
    private string _newApp = "";
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _keys = await Api.GetApiKeysAsync();
        _loading = false;
    }

    private async Task CreateKey()
    {
        if (string.IsNullOrWhiteSpace(_newLabel)) return;
        var result = await Api.CreateApiKeyAsync(_newLabel, string.IsNullOrEmpty(_newApp) ? null : _newApp);
        if (result == null)
        {
            Snackbar.Add("Failed to create API key. Check the browser console for details.", Severity.Error);
            return;
        }

        _newLabel = "";
        _newApp = "";
        _keys = await Api.GetApiKeysAsync();

        var parameters = new DialogParameters<ApiKeyRevealDialog>
        {
            { x => x.Title, "API Key Created" },
            { x => x.RawKey, result.RawKey },
            { x => x.Label, result.Label }
        };
        await DialogService.ShowAsync<ApiKeyRevealDialog>("API Key Created", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
    }

    private async Task Rotate(int id)
    {
        var result = await Api.RotateApiKeyAsync(id);
        _keys = await Api.GetApiKeysAsync();
        if (result != null)
        {
            var expiry = result.OldKeyExpiresAt?.ToLocalTime().ToString("MM/dd HH:mm");
            var parameters = new DialogParameters<ApiKeyRevealDialog>
            {
                { x => x.Title, "API Key Rotated" },
                { x => x.RawKey, result.RawKey },
                { x => x.Label, result.Label },
                { x => x.OldKeyExpiry, expiry != null ? $"Old key expires: {expiry}" : null }
            };
            await DialogService.ShowAsync<ApiKeyRevealDialog>("API Key Rotated", parameters,
                new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        }
    }

    private async Task ConfirmRevoke(ApiKeyDto key)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Title, "Revoke API Key" },
            { x => x.Message, $"Revoke \"{key.Label}\"? All requests using this key will be rejected immediately." },
            { x => x.ConfirmText, "Revoke" }
        };
        var result = await DialogService.ShowAsync<ConfirmDialog>("Confirm", parameters,
            new DialogOptions { MaxWidth = MaxWidth.ExtraSmall });
        var dialogResult = await result.Result;
        if (!dialogResult.Canceled)
        {
            await Api.RevokeApiKeyAsync(key.Id);
            _keys = await Api.GetApiKeysAsync();
            Snackbar.Add($"Key \"{key.Label}\" revoked.", Severity.Warning);
        }
    }
}
