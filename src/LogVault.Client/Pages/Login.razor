@page "/login"
@layout EmptyLayout
@inject ILogVaultApiClient Api
@inject AuthStateService Auth
@inject NavigationManager Nav

<PageTitle>Sign In — LogVault</PageTitle>

<div style="min-height:100vh; display:flex; align-items:center; justify-content:center; background:var(--mud-palette-background)">
    <MudPaper Elevation="4" Style="width:100%; max-width:420px; border-radius:16px" Class="pa-8 ma-4">
        <div class="d-flex flex-column align-center mb-6">
            <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Style="font-size:3rem" />
            <MudText Typo="Typo.h4" Align="Align.Center" Class="mt-2" Style="font-weight:700">
                Log<span style="color:var(--mud-palette-primary)">Vault</span>
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary mt-1">
                Sign in to your account
            </MudText>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4" Dense="true"
                      ShowCloseIcon="true" CloseIconClicked="() => _error = null">
                @_error
            </MudAlert>
        }

        <MudTextField @bind-Value="_username"
                      Label="Username"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Person"
                      Class="mb-4"
                      Disabled="@_busy"
                      OnKeyUp="OnKeyUp" />

        <MudTextField @bind-Value="_password"
                      Label="Password"
                      Variant="Variant.Outlined"
                      InputType="@_passwordInputType"
                      Adornment="Adornment.End"
                      AdornmentIcon="@_passwordIcon"
                      OnAdornmentClick="TogglePasswordVisibility"
                      Class="mb-4"
                      Disabled="@_busy"
                      OnKeyUp="OnKeyUp" />

        <div class="d-flex justify-space-between align-center mb-6">
            <MudCheckBox @bind-Value="_rememberMe" Label="Remember me" Color="Color.Primary" Dense="true" />
        </div>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   OnClick="DoLogin"
                   Disabled="@_busy"
                   Style="border-radius:8px; text-transform:none; font-size:1rem; font-weight:600">
            @if (_busy)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Signing in...</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </MudButton>
    </MudPaper>
</div>

@code {
    private string _username = "";
    private string _password = "";
    private bool _rememberMe;
    private bool _busy;
    private string? _error;
    private bool _showPassword;

    private InputType _passwordInputType => _showPassword ? InputType.Text : InputType.Password;
    private string _passwordIcon => _showPassword
        ? Icons.Material.Filled.VisibilityOff
        : Icons.Material.Filled.Visibility;

    protected override async Task OnInitializedAsync()
    {
        var user = await Api.GetMeAsync();
        if (user != null)
        {
            Auth.SetUser(user);
            Nav.NavigateTo("/dashboard");
        }
    }

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await DoLogin();
    }

    private async Task DoLogin()
    {
        _error = null;
        _busy = true;
        try
        {
            var result = await Api.LoginAsync(_username, _password, _rememberMe);
            if (result == null)
            {
                _error = "Invalid username or password.";
                return;
            }
            Auth.SetUser(new UserInfo(result.Username, result.DisplayName, result.Email, result.Roles, "Cookie"));
            Nav.NavigateTo("/dashboard");
        }
        finally
        {
            _busy = false;
        }
    }
}
