@page "/logs"
@using Microsoft.AspNetCore.SignalR.Client
@using System.Text.Json
@inject ILogVaultApiClient Api
@inject NavigationManager Nav
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Log Explorer — LogVault</PageTitle>

<MudText Typo="Typo.h5" Class="mb-1" Style="font-weight:700">Log Explorer</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">Search, filter, and tail your log stream</MudText>

@* Filter bar *@
<MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius:12px">

    @* Mode toggle header *@
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="text-transform:uppercase;letter-spacing:.05em">Filters</MudText>
        <MudToggleGroup T="string" @bind-Value="_filterMode" Size="Size.Small" Dense="true" Color="Color.Primary">
            <MudToggleItem Value='"form"'>
                <MudIcon Icon="@Icons.Material.Filled.Tune" Size="Size.Small" Class="mr-1" />Form
            </MudToggleItem>
            <MudToggleItem Value='"expr"'>
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Class="mr-1" />Expression
            </MudToggleItem>
        </MudToggleGroup>
    </div>

    @* Date range — always visible *@
    <MudGrid Spacing="2" Class="mb-2">
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker Label="From"
                               @bind-Date="_from"
                               Variant="Variant.Outlined"
                               Disabled="@_liveTailActive"
                               DateFormat="yyyy-MM-dd HH:mm"
                               Clearable="true"
                               Dense="true" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudDatePicker Label="To"
                               @bind-Date="_to"
                               Variant="Variant.Outlined"
                               Disabled="@_liveTailActive"
                               DateFormat="yyyy-MM-dd HH:mm"
                               Clearable="true"
                               Dense="true" />
        </MudItem>
    </MudGrid>

    @* Form mode *@
    @if (_filterMode == "form")
    {
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4" md="2">
                <MudSelect T="string" Label="Level" @bind-Value="_level"
                           Variant="Variant.Outlined"
                           Disabled="@_liveTailActive"
                           Clearable="true"
                           Dense="true">
                    <MudSelectItem Value='""'>Any</MudSelectItem>
                    <MudSelectItem Value='"Verbose"'>Verbose</MudSelectItem>
                    <MudSelectItem Value='"Debug"'>Debug</MudSelectItem>
                    <MudSelectItem Value='"Information"'>Information</MudSelectItem>
                    <MudSelectItem Value='"Warning"'>Warning</MudSelectItem>
                    <MudSelectItem Value='"Error"'>Error</MudSelectItem>
                    <MudSelectItem Value='"Fatal"'>Fatal</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <MudTextField @bind-Value="_app"
                              Label="Application"
                              Variant="Variant.Outlined"
                              Placeholder="Any"
                              Disabled="@_liveTailActive"
                              Clearable="true"
                              Dense="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Apps" />
            </MudItem>
            <MudItem xs="12" sm="4" md="4">
                <MudTextField @bind-Value="_search"
                              Label="Search"
                              Variant="Variant.Outlined"
                              Placeholder="message, exception, properties..."
                              Disabled="@_liveTailActive"
                              Clearable="true"
                              Dense="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              HelperText="Searches all fields — space-separated terms (AND)" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" sm="4" md="3">
                <MudTextField @bind-Value="_propKey"
                              Label="Property Key"
                              Variant="Variant.Outlined"
                              Placeholder="e.g. UserId"
                              Disabled="@_liveTailActive"
                              Clearable="true"
                              Dense="true"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.DataObject" />
            </MudItem>
            <MudItem xs="12" sm="3" md="2">
                <MudSelect T="string" @bind-Value="_propOp"
                           Label="Operator"
                           Variant="Variant.Outlined"
                           Disabled="@_liveTailActive"
                           Dense="true">
                    <MudSelectItem Value='"Contains"'>Contains</MudSelectItem>
                    <MudSelectItem Value='"Equals"'>= Equals</MudSelectItem>
                    <MudSelectItem Value='"NotEquals"'>≠ Not equals</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="5" md="3">
                <MudTextField @bind-Value="_propValue"
                              Label="Property Value"
                              Variant="Variant.Outlined"
                              Placeholder="e.g. 42"
                              Disabled="@(string.IsNullOrEmpty(_propKey) || _liveTailActive)"
                              Clearable="true"
                              Dense="true" />
            </MudItem>
        </MudGrid>
    }
    else
    {
        @* Expression mode *@
        <MudTextField @bind-Value="_exprText"
                      Label="Query Expression"
                      Variant="Variant.Outlined"
                      Placeholder='level >= Warning AND app == "MyApp" AND prop:UserId == "42"'
                      Disabled="@_liveTailActive"
                      Lines="2"
                      AutoGrow="true"
                      Clearable="true"
                      FullWidth="true"
                      Style="font-family:monospace"
                      HelperText='Fields: level, app, env, message, exception, trace, timestamp, prop:Key  •  Ops: ==  !=  contains  >=  <=  >  <  •  Combine with AND'
                      Error="@(!string.IsNullOrEmpty(_exprError))"
                      ErrorText="@_exprError"
                      Immediate="false"
                      OnKeyDown="OnExprKeyDown" />
    }

    <div class="d-flex align-center gap-2 mt-3 flex-wrap">
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Search"
                   OnClick="Search"
                   Disabled="@_liveTailActive"
                   Size="Size.Small">
            Search
        </MudButton>
        <MudButton Variant="@(_liveTailActive ? Variant.Filled : Variant.Outlined)"
                   Color="@(_liveTailActive ? Color.Error : Color.Success)"
                   StartIcon="@(_liveTailActive ? Icons.Material.Filled.Stop : Icons.Material.Filled.PlayArrow)"
                   OnClick="ToggleLiveTail"
                   Size="Size.Small">
            @(_liveTailActive ? "Stop Live Tail" : "Live Tail")
        </MudButton>
        @if (_liveTailActive)
        {
            <MudChip T="string" Color="Color.Success" Size="Size.Small"
                     Icon="@Icons.Material.Filled.FiberManualRecord"
                     Style="animation: pulse 1.5s infinite">
                LIVE
            </MudChip>
        }

        <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />

        @* Pinned filter chips *@
        @if (_savedFilters != null && _savedFilters.Any(f => f.IsPinned))
        {
            @foreach (var sf in _savedFilters.Where(f => f.IsPinned))
            {
                <MudChip T="string"
                         Color="Color.Primary"
                         Variant="Variant.Outlined"
                         Size="Size.Small"
                         Icon="@Icons.Material.Filled.PushPin"
                         OnClick="@(() => LoadFilter(sf))"
                         Disabled="@_liveTailActive">
                    @sf.Name
                </MudChip>
            }
            <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
        }

        @* Saved filters *@
        @if (_savedFilters != null && _savedFilters.Count > 0)
        {
            <MudMenu Label="Filters" StartIcon="@Icons.Material.Filled.BookmarkBorder"
                     Variant="Variant.Outlined" Size="Size.Small" Dense="true"
                     Disabled="@_liveTailActive">
                @foreach (var sf in _savedFilters)
                {
                    <MudMenuItem OnClick="() => LoadFilter(sf)">
                        <div class="d-flex align-center justify-space-between" style="min-width:180px">
                            <MudText Typo="Typo.body2">@sf.Name</MudText>
                            <div class="d-flex gap-0">
                                <MudTooltip Text="@(sf.IsPinned ? "Unpin filter" : "Pin filter")">
                                    <div @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@(sf.IsPinned ? Icons.Material.Filled.PushPin : Icons.Material.Outlined.PushPin)"
                                                       Size="Size.Small"
                                                       Color="@(sf.IsPinned ? Color.Primary : Color.Default)"
                                                       OnClick="@(() => TogglePin(sf))" />
                                    </div>
                                </MudTooltip>
                                <MudTooltip Text="Delete filter">
                                    <div @onclick:stopPropagation="true">
                                        <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                                       Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeleteFilter(sf))" />
                                    </div>
                                </MudTooltip>
                            </div>
                        </div>
                    </MudMenuItem>
                }
            </MudMenu>
        }

        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.Bookmark"
                   Size="Size.Small"
                   Disabled="@_liveTailActive"
                   OnClick="OpenSaveFilterDialog">
            Save Filter
        </MudButton>

        <MudSpacer />
        @if (_result != null && !_liveTailActive)
        {
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                @_result.TotalCount.ToString("N0") events found
            </MudText>
        }
    </div>
</MudPaper>

@* Save filter dialog *@
@if (_showSaveDialog)
{
    <MudPaper Elevation="4" Class="pa-4 mb-4" Style="border-radius:12px; border:1px solid var(--mud-palette-primary)">
        <MudText Typo="Typo.subtitle2" Class="mb-3">Save Current Filter</MudText>
        <div class="d-flex align-center gap-2">
            <MudTextField @bind-Value="_saveFilterName"
                          Label="Filter name"
                          Variant="Variant.Outlined"
                          Dense="true"
                          Placeholder="e.g. Production Errors"
                          Class="flex-1"
                          Immediate="true" />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Small"
                       OnClick="SaveFilter"
                       Disabled="@string.IsNullOrWhiteSpace(_saveFilterName)">
                Save
            </MudButton>
            <MudButton Variant="Variant.Text"
                       Size="Size.Small"
                       OnClick="() => _showSaveDialog = false">
                Cancel
            </MudButton>
        </div>
    </MudPaper>
}

@* Results table *@
<MudPaper Elevation="2" Style="border-radius:12px; overflow:hidden">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }

    <MudTable T="LogEventDto"
              Items="@_events"
              Dense="true"
              Hover="true"
              Elevation="0"
              OnRowClick="OnRowClick"
              RowStyle="cursor:pointer"
              Loading="@_loading"
              LoadingProgressColor="Color.Primary"
              Style="background:transparent">
        <HeaderContent>
            <MudTh Style="white-space:nowrap">Time</MudTh>
            <MudTh>Level</MudTh>
            <MudTh>Application</MudTh>
            <MudTh>Message</MudTh>
            <MudTh Style="width:32px"></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="white-space:nowrap; font-size:0.8rem; font-family:monospace">
                @context.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")
            </MudTd>
            <MudTd><LogLevelChip Level="@context.Level" /></MudTd>
            <MudTd>
                <MudText Typo="Typo.body2" Style="font-size:0.825rem">@context.SourceApplication</MudText>
            </MudTd>
            <MudTd Style="max-width:600px">
                <MudText Typo="Typo.body2" Style="font-size:0.825rem; overflow:hidden; text-overflow:ellipsis; white-space:nowrap">
                    @Truncate(context.RenderedMessage, 120)
                </MudText>
            </MudTd>
            <MudTd>
                <div class="d-flex gap-1">
                    @if (context.Exception != null)
                    {
                        <MudTooltip Text="Has exception">
                            <MudIcon Icon="@Icons.Material.Filled.BugReport" Color="Color.Error" Size="Size.Small" />
                        </MudTooltip>
                    }
                    @if (context.TraceId != null)
                    {
                        <MudTooltip Text="@($"Trace: {context.TraceId}")">
                            <MudIconButton Icon="@Icons.Material.Filled.AccountTree"
                                           Size="Size.Small"
                                           Color="Color.Info"
                                           Href="@($"/traces/{Uri.EscapeDataString(context.TraceId)}")"
                                           @onclick:stopPropagation="true" />
                        </MudTooltip>
                    }
                </div>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4 mud-text-secondary">No log events found.</MudText>
        </NoRecordsContent>
    </MudTable>

    @if (!_liveTailActive && _result != null)
    {
        <div class="d-flex align-center justify-space-between pa-3" style="border-top:1px solid var(--mud-palette-table-lines)">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Page @_page of @TotalPages (@_result.TotalCount.ToString("N0") total)
            </MudText>
            <div class="d-flex gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                               Size="Size.Small"
                               Disabled="@(_page <= 1)"
                               OnClick="PrevPage" />
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                               Size="Size.Small"
                               Disabled="@(_page >= TotalPages)"
                               OnClick="NextPage" />
            </div>
        </div>
    }
</MudPaper>

@code {
    private List<LogEventDto> _events = new();
    private PagedResult<LogEventDto>? _result;
    private bool _loading;
    private bool _liveTailActive;
    private HubConnection? _hubConnection;

    private DateTime? _from;
    private DateTime? _to;
    private string _level = "";
    private string _app = "";
    private string _search = "";
    private string _propKey = "";
    private string _propOp = "Contains";
    private string _propValue = "";
    private int _page = 1;
    private int _pageSize = 50;

    // Expression mode
    private string _filterMode = "form"; // "form" | "expr"
    private string _exprText = "";
    private string _exprError = "";

    private List<SavedFilterDto>? _savedFilters;
    private bool _showSaveDialog;
    private string _saveFilterName = "";

    private static readonly JsonSerializerOptions _jsonOpts = new() { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };

    private int TotalPages => _result == null ? 1 : Math.Max(1, (_result.TotalCount + _pageSize - 1) / _pageSize);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(Search(), LoadSavedFilters());
    }

    private async Task LoadSavedFilters()
    {
        _savedFilters = await Api.GetSavedFiltersAsync();
    }

    private async Task Search()
    {
        _exprError = "";
        _loading = true;

        LogQuery query;
        if (_filterMode == "expr")
        {
            query = new LogQuery(
                From: _from.HasValue ? (DateTimeOffset?)new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
                To: _to.HasValue ? (DateTimeOffset?)new DateTimeOffset(_to.Value, TimeSpan.Zero) : null,
                Expr: string.IsNullOrWhiteSpace(_exprText) ? null : _exprText,
                Page: _page, PageSize: _pageSize, Desc: true);
        }
        else
        {
            query = new LogQuery(
                From: _from.HasValue ? (DateTimeOffset?)new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
                To: _to.HasValue ? (DateTimeOffset?)new DateTimeOffset(_to.Value, TimeSpan.Zero) : null,
                Level: string.IsNullOrEmpty(_level) ? null : _level,
                App: string.IsNullOrEmpty(_app) ? null : _app,
                Fts: string.IsNullOrEmpty(_search) ? null : _search,
                Prop: string.IsNullOrEmpty(_propKey) ? null : _propKey,
                PropValue: string.IsNullOrEmpty(_propValue) ? null : _propValue,
                PropOp: _propOp == "Contains" ? null : _propOp,
                Page: _page, PageSize: _pageSize, Desc: true);
        }

        _result = await Api.QueryLogsAsync(query);

        // Surface expression parse errors returned by the API
        if (_result == null && _filterMode == "expr" && !string.IsNullOrWhiteSpace(_exprText))
            _exprError = "Invalid expression — check syntax and try again.";

        _events = _result?.Items ?? new();
        _loading = false;
    }

    private async Task OnExprKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            _page = 1;
            await Search();
        }
    }

    private void OpenSaveFilterDialog()
    {
        _saveFilterName = "";
        _showSaveDialog = true;
    }

    private async Task SaveFilter()
    {
        var data = _filterMode == "expr"
            ? new SavedFilterData(
                From: _from.HasValue ? (DateTimeOffset?)new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
                To: _to.HasValue ? (DateTimeOffset?)new DateTimeOffset(_to.Value, TimeSpan.Zero) : null,
                Level: null, App: null, Env: null, Q: null,
                TraceId: null, Prop: null, PropValue: null,
                Fts: null,
                Expr: string.IsNullOrWhiteSpace(_exprText) ? null : _exprText)
            : new SavedFilterData(
                From: _from.HasValue ? (DateTimeOffset?)new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
                To: _to.HasValue ? (DateTimeOffset?)new DateTimeOffset(_to.Value, TimeSpan.Zero) : null,
                Level: string.IsNullOrEmpty(_level) ? null : _level,
                App: string.IsNullOrEmpty(_app) ? null : _app,
                Env: null, Q: null,
                TraceId: null, Prop: null, PropValue: null,
                Fts: string.IsNullOrEmpty(_search) ? null : _search);

        var json = JsonSerializer.Serialize(data, _jsonOpts);
        var result = await Api.CreateSavedFilterAsync(_saveFilterName, json);
        if (result != null)
        {
            _savedFilters ??= new();
            _savedFilters.Add(result);
            _savedFilters = _savedFilters.OrderBy(f => f.Name).ToList();
            Snackbar.Add($"Filter \"{result.Name}\" saved.", Severity.Success);
        }
        _showSaveDialog = false;
        _saveFilterName = "";
    }

    private async Task LoadFilter(SavedFilterDto sf)
    {
        try
        {
            var data = JsonSerializer.Deserialize<SavedFilterData>(sf.FilterJson, _jsonOpts);
            if (data == null) return;

            _from = data.From?.LocalDateTime;
            _to = data.To?.LocalDateTime;
            _page = 1;

            if (!string.IsNullOrWhiteSpace(data.Expr))
            {
                _filterMode = "expr";
                _exprText = data.Expr;
                _exprError = "";
            }
            else
            {
                _filterMode = "form";
                _level = data.Level ?? "";
                _app = data.App ?? "";
                _search = data.Fts ?? data.Q ?? "";
                _propKey = data.Prop ?? "";
                _propValue = data.PropValue ?? "";
            }

            Snackbar.Add($"Loaded filter \"{sf.Name}\".", Severity.Info);
            await Search();
        }
        catch
        {
            Snackbar.Add("Failed to load filter.", Severity.Error);
        }
    }

    private async Task DeleteFilter(SavedFilterDto sf)
    {
        await Api.DeleteSavedFilterAsync(sf.Id);
        _savedFilters?.Remove(sf);
        Snackbar.Add($"Filter \"{sf.Name}\" deleted.", Severity.Warning);
    }

    private async Task TogglePin(SavedFilterDto sf)
    {
        var updated = await Api.PinSavedFilterAsync(sf.Id);
        if (updated != null && _savedFilters != null)
        {
            var idx = _savedFilters.FindIndex(f => f.Id == sf.Id);
            if (idx >= 0) _savedFilters[idx] = updated;
        }
    }

    private async Task OnRowClick(TableRowClickEventArgs<LogEventDto> args)
    {
        var parameters = new DialogParameters<LogDetailDialog>
        {
            { x => x.Event, args.Item }
        };
        await DialogService.ShowAsync<LogDetailDialog>("Event Detail", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private async Task ToggleLiveTail()
    {
        if (_liveTailActive) await StopLiveTailAsync();
        else await StartLiveTailAsync();
    }

    private async Task StartLiveTailAsync()
    {
        _liveTailActive = true;
        _events = new();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/logs"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<LogEventDto>>("NewEvents", newEvents =>
        {
            _events.InsertRange(0, newEvents);
            if (_events.Count > 500) _events = _events.Take(500).ToList();
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await _hubConnection.SendAsync("SetFilter", new
        {
            MinLevel = string.IsNullOrEmpty(_level) ? (object?)null : _level,
            SourceApplication = string.IsNullOrEmpty(_app) ? null : _app,
            MessageContains = string.IsNullOrEmpty(_search) ? null : _search
        });
    }

    private async Task StopLiveTailAsync()
    {
        _liveTailActive = false;
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
            _hubConnection = null;
        }
    }

    private async Task PrevPage() { if (_page > 1) { _page--; await Search(); } }
    private async Task NextPage() { if (_page < TotalPages) { _page++; await Search(); } }

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
            await _hubConnection.DisposeAsync();
    }
}
