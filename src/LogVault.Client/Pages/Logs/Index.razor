@page "/logs"
@using Microsoft.AspNetCore.SignalR.Client
@inject ILogVaultApiClient Api
@inject NavigationManager Nav
@implements IAsyncDisposable

<h1>Log Explorer</h1>

<div class="row mb-3">
    <div class="col-md-3">
        <label class="form-label">From</label>
        <input type="datetime-local" class="form-control" @bind="_from" disabled="@_liveTailActive" />
    </div>
    <div class="col-md-3">
        <label class="form-label">To</label>
        <input type="datetime-local" class="form-control" @bind="_to" disabled="@_liveTailActive" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Level</label>
        <select class="form-select" @bind="_level" disabled="@_liveTailActive">
            <option value="">Any</option>
            <option>Verbose</option>
            <option>Debug</option>
            <option>Information</option>
            <option>Warning</option>
            <option>Error</option>
            <option>Fatal</option>
        </select>
    </div>
    <div class="col-md-2">
        <label class="form-label">Application</label>
        <input class="form-control" @bind="_app" placeholder="Any" disabled="@_liveTailActive" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Search</label>
        <input class="form-control" @bind="_search" placeholder="message..." disabled="@_liveTailActive" />
    </div>
</div>

<div class="mb-3 d-flex gap-2">
    <button class="btn btn-primary" @onclick="Search" disabled="@_liveTailActive">Search</button>
    <button class="btn @(_liveTailActive ? "btn-danger" : "btn-outline-success")" @onclick="ToggleLiveTail">
        @(_liveTailActive ? "Stop Live Tail" : "Live Tail")
    </button>
    @if (_liveTailActive)
    {
        <span class="badge bg-success align-self-center">LIVE</span>
    }
</div>

@if (_loading)
{
    <p>Searching...</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Time</th>
                <th>Level</th>
                <th>Application</th>
                <th>Message</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ev in _events)
        {
            <tr @onclick="() => SelectEvent(ev)" style="cursor:pointer">
                <td style="white-space:nowrap">@ev.Timestamp.ToLocalTime().ToString("MM/dd HH:mm:ss")</td>
                <td><span class="badge @GetLevelClass(ev.Level)">@ev.Level</span></td>
                <td>@ev.SourceApplication</td>
                <td>@Truncate(ev.RenderedMessage, 100)</td>
                <td>@(ev.Exception != null ? "!" : "")</td>
            </tr>
        }
        </tbody>
    </table>

    @if (!_liveTailActive && _result != null)
    {
        <div class="d-flex gap-2 align-items-center">
            <span>Page @_page of @((_result.TotalCount + _pageSize - 1) / _pageSize) (@_result.TotalCount total)</span>
            <button class="btn btn-sm btn-outline-secondary" @onclick="PrevPage" disabled="@(_page <= 1)">Prev</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="NextPage"
                disabled="@(_page * _pageSize >= _result.TotalCount)">Next</button>
        </div>
    }
}

@if (_selectedEvent != null)
{
    <div class="modal show d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Event Detail — @_selectedEvent.Id</h5>
                    <button class="btn-close" @onclick="() => _selectedEvent = null"></button>
                </div>
                <div class="modal-body">
                    <dl class="row">
                        <dt class="col-3">Time</dt><dd class="col-9">@_selectedEvent.Timestamp.ToLocalTime()</dd>
                        <dt class="col-3">Level</dt><dd class="col-9"><span class="badge @GetLevelClass(_selectedEvent.Level)">@_selectedEvent.Level</span></dd>
                        <dt class="col-3">Application</dt><dd class="col-9">@_selectedEvent.SourceApplication</dd>
                        <dt class="col-3">Environment</dt><dd class="col-9">@_selectedEvent.SourceEnvironment</dd>
                        <dt class="col-3">Message</dt><dd class="col-9">@_selectedEvent.RenderedMessage</dd>
                        @if (_selectedEvent.TraceId != null)
                        {
                            <dt class="col-3">Trace ID</dt><dd class="col-9"><code>@_selectedEvent.TraceId</code></dd>
                        }
                    </dl>
                    @if (_selectedEvent.Exception != null)
                    {
                        <h6>Exception</h6>
                        <pre style="font-size:0.8em;overflow:auto;background:#f8f8f8;padding:8px">@_selectedEvent.Exception</pre>
                    }
                    <h6>Properties</h6>
                    <pre style="font-size:0.8em;overflow:auto;background:#f8f8f8;padding:8px">@_selectedEvent.PropertiesJson</pre>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop show"></div>
}

@code {
    private List<LogEventDto> _events = new();
    private PagedResult<LogEventDto>? _result;
    private LogEventDto? _selectedEvent;
    private bool _loading;
    private bool _liveTailActive;
    private HubConnection? _hubConnection;

    private DateTime? _from;
    private DateTime? _to;
    private string _level = "";
    private string _app = "";
    private string _search = "";
    private int _page = 1;
    private int _pageSize = 50;

    protected override async Task OnInitializedAsync() => await Search();

    private async Task Search()
    {
        _loading = true;
        _result = await Api.QueryLogsAsync(new LogQuery(
            From: _from.HasValue ? (DateTimeOffset?)new DateTimeOffset(_from.Value, TimeSpan.Zero) : null,
            To: _to.HasValue ? (DateTimeOffset?)new DateTimeOffset(_to.Value, TimeSpan.Zero) : null,
            Level: string.IsNullOrEmpty(_level) ? null : _level,
            App: string.IsNullOrEmpty(_app) ? null : _app,
            Q: string.IsNullOrEmpty(_search) ? null : _search,
            Page: _page, PageSize: _pageSize, Desc: true));

        _events = _result?.Items ?? new();
        _loading = false;
    }

    private async Task ToggleLiveTail()
    {
        if (_liveTailActive)
        {
            await StopLiveTailAsync();
        }
        else
        {
            await StartLiveTailAsync();
        }
    }

    private async Task StartLiveTailAsync()
    {
        _liveTailActive = true;
        _events = new();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/hubs/logs"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<List<LogEventDto>>("NewEvents", newEvents =>
        {
            _events.InsertRange(0, newEvents);
            if (_events.Count > 500) _events = _events.Take(500).ToList();
            InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await _hubConnection.SendAsync("SetFilter", new
        {
            MinLevel = string.IsNullOrEmpty(_level) ? (object?)null : _level,
            SourceApplication = string.IsNullOrEmpty(_app) ? null : _app,
            MessageContains = string.IsNullOrEmpty(_search) ? null : _search
        });
    }

    private async Task StopLiveTailAsync()
    {
        _liveTailActive = false;
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
            _hubConnection = null;
        }
    }

    private void SelectEvent(LogEventDto ev) => _selectedEvent = ev;

    private async Task PrevPage() { if (_page > 1) { _page--; await Search(); } }
    private async Task NextPage() { _page++; await Search(); }

    private static string GetLevelClass(string level) => level switch
    {
        "Fatal" => "bg-dark",
        "Error" => "bg-danger",
        "Warning" => "bg-warning text-dark",
        "Information" => "bg-info text-dark",
        "Debug" => "bg-secondary",
        _ => "bg-light text-dark"
    };

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
            await _hubConnection.DisposeAsync();
    }
}
