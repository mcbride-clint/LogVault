@page "/dashboard"
@page "/"
@inject ILogVaultApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Dashboard — LogVault</PageTitle>

@if (_dashboard == null && _loading)
{
    <MudText Typo="Typo.h5" Class="mb-6" Style="font-weight:700">Dashboard</MudText>
    <MudGrid>
        @for (int i = 0; i < 4; i++)
        {
            <MudItem xs="12" sm="6">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="180px" Class="rounded-lg" />
            </MudItem>
        }
    </MudGrid>
}
else if (_dashboard != null)
{
    <div class="d-flex align-center gap-2 mb-1">
        <MudText Typo="Typo.h5" Style="font-weight:700">
            @(_editingName ? "" : _dashboard.Name)
        </MudText>
        @if (_editingName)
        {
            <MudTextField @bind-Value="_nameInput" Variant="Variant.Outlined" Dense="true"
                          Style="max-width:250px" Immediate="true" />
            <MudIconButton Icon="@Icons.Material.Filled.Check" Color="Color.Success"
                           Size="Size.Small" OnClick="SaveName" />
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                           OnClick="@(() => _editingName = false)" />
        }
        else
        {
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                           Class="mud-text-secondary" OnClick="@(() => { _nameInput = _dashboard.Name; _editingName = true; })" />
        }
        <MudSpacer />
        @if (!_editMode)
        {
            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Dashboard"
                       OnClick="@(() => _editMode = true)">
                Edit Widgets
            </MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveWidgets">
                Save
            </MudButton>
            <MudButton Variant="Variant.Text" Size="Size.Small"
                       OnClick="@(() => _editMode = false)">
                Cancel
            </MudButton>
        }
    </div>
    <MudText Typo="Typo.body2" Class="mud-text-secondary mb-6">
        @(_editMode ? "Add, remove, or reorder widgets." : "Your personalized dashboard.")
    </MudText>

    @* Edit mode: widget manager *@
    @if (_editMode)
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4" Style="border-radius:12px">
            <MudText Typo="Typo.subtitle2" Class="mb-3">Widget List</MudText>
            @for (int i = 0; i < _editWidgets.Count; i++)
            {
                var idx = i;
                var w = _editWidgets[idx];
                <div class="d-flex align-center gap-2 mb-2">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                   Disabled="@(idx == 0)"
                                   OnClick="@(() => MoveWidget(idx, -1))" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                   Disabled="@(idx == _editWidgets.Count - 1)"
                                   OnClick="@(() => MoveWidget(idx, 1))" />
                    <MudText Typo="Typo.body2" Style="flex:1">@w.Title <span style="opacity:0.5">(@w.WidgetType)</span></MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => _editWidgets.RemoveAt(idx))" />
                </div>
            }
            <MudDivider Class="my-3" />
            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">Add widget:</MudText>
            <div class="d-flex gap-2 flex-wrap">
                @foreach (var (type, label) in AvailableWidgetTypes)
                {
                    <MudButton Variant="Variant.Outlined" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="@(() => AddWidget(type, label))">
                        @label
                    </MudButton>
                }
            </div>
        </MudPaper>
    }

    @* Widget grid *@
    <MudGrid Spacing="3">
        @foreach (var widget in (_editMode ? _editWidgets : _dashboard.Widgets).OrderBy(w => w.SortOrder))
        {
            var cols = widget.WidgetType is "ErrorList" or "TopApplications" ? 12 : 6;
            <MudItem xs="12" md="@cols">
                @RenderWidget(widget)
            </MudItem>
        }
    </MudGrid>
}

@code {
    private DashboardDto? _dashboard;
    private bool _loading = true;
    private bool _editMode;
    private bool _editingName;
    private string _nameInput = "";
    private List<DashboardWidgetDto> _editWidgets = [];

    private static readonly (string Type, string Label)[] AvailableWidgetTypes =
    [
        ("ByLevel",        "Events by Level"),
        ("EventRate",      "Event Rate"),
        ("ErrorList",      "Recent Errors"),
        ("TopApplications","Top Applications"),
    ];

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await Api.GetDefaultDashboardAsync();
        _loading = false;
    }

    private void StartEdit()
    {
        _editWidgets = [.. _dashboard!.Widgets.OrderBy(w => w.SortOrder)
            .Select(w => new DashboardWidgetDto(w.Id, w.WidgetType, w.Title, w.SortOrder, w.ConfigJson))];
        _editMode = true;
    }

    private void MoveWidget(int idx, int direction)
    {
        var newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= _editWidgets.Count) return;
        (_editWidgets[idx], _editWidgets[newIdx]) = (_editWidgets[newIdx], _editWidgets[idx]);
        for (int i = 0; i < _editWidgets.Count; i++)
            _editWidgets[i] = _editWidgets[i] with { SortOrder = i };
    }

    private void AddWidget(string type, string label)
    {
        _editWidgets.Add(new DashboardWidgetDto(0, type, label, _editWidgets.Count, DefaultConfig(type)));
    }

    private async Task SaveWidgets()
    {
        var specs = _editWidgets.Select((w, i) => new WidgetSpecDto(w.WidgetType, w.Title, i, w.ConfigJson)).ToList();
        var updated = await Api.UpdateDashboardWidgetsAsync(_dashboard!.Id, specs);
        if (updated != null)
        {
            _dashboard = updated;
            Snackbar.Add("Dashboard saved.", Severity.Success);
        }
        else
        {
            Snackbar.Add("Failed to save dashboard.", Severity.Error);
        }
        _editMode = false;
    }

    private async Task SaveName()
    {
        if (string.IsNullOrWhiteSpace(_nameInput)) return;
        var updated = await Api.UpdateDashboardAsync(_dashboard!.Id, _nameInput, _dashboard.IsDefault);
        if (updated != null) _dashboard = updated;
        _editingName = false;
    }

    private static string DefaultConfig(string type) => type switch
    {
        "ByLevel"         => """{"hours":24}""",
        "EventRate"       => """{"hours":12}""",
        "ErrorList"       => """{"hours":24,"limit":20}""",
        "TopApplications" => """{"hours":24,"limit":10}""",
        _                 => "{}"
    };

    private RenderFragment RenderWidget(DashboardWidgetDto w) => w.WidgetType switch
    {
        "ByLevel"         => @<ByLevelWidget Title="@w.Title" Hours="@ParseHours(w.ConfigJson)" />,
        "EventRate"       => @<EventRateWidget Title="@w.Title" Hours="@ParseHours(w.ConfigJson)" />,
        "ErrorList"       => @<ErrorListWidget Title="@w.Title" Hours="@ParseHours(w.ConfigJson)" Limit="@ParseLimit(w.ConfigJson)" />,
        "TopApplications" => @<TopApplicationsWidget Title="@w.Title" Hours="@ParseHours(w.ConfigJson)" Limit="@ParseLimit(w.ConfigJson)" />,
        _                 => @<MudPaper Elevation="2" Class="pa-4" Style="border-radius:12px"><MudText>Unknown widget: @w.WidgetType</MudText></MudPaper>
    };

    private static int ParseHours(string configJson)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(configJson);
            if (doc.RootElement.TryGetProperty("hours", out var h)) return h.GetInt32();
        }
        catch { }
        return 24;
    }

    private static int ParseLimit(string configJson)
    {
        try
        {
            var doc = System.Text.Json.JsonDocument.Parse(configJson);
            if (doc.RootElement.TryGetProperty("limit", out var l)) return l.GetInt32();
        }
        catch { }
        return 20;
    }
}
