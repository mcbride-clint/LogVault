@page "/not-found"
@layout MainLayout

<PageTitle>Not Found — LogVault</PageTitle>

<div class="d-flex flex-column align-center justify-center" style="min-height:60vh">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff"
             Style="font-size:6rem; opacity:0.2"
             Class="mb-4" />
    <MudText Typo="Typo.h4" Align="Align.Center" Style="font-weight:700" Class="mb-2">
        404 — Page Not Found
    </MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mud-text-secondary mb-6">
        The page you're looking for doesn't exist or has been moved.
    </MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Home"
               Href="/dashboard"
               Size="Size.Large">
        Back to Dashboard
    </MudButton>
</div>
