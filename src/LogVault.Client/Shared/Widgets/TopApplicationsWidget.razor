@inject ILogVaultApiClient Api

<MudPaper Elevation="2" Class="pa-4 h-100" Style="border-radius:12px">
    <MudText Typo="Typo.subtitle1" Class="mb-3">@Title</MudText>
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_apps?.Count > 0)
    {
        var maxCount = _apps.Max(a => a.Count);
        @foreach (var app in _apps)
        {
            var pct = maxCount > 0 ? (double)app.Count / maxCount * 100 : 0;
            <div class="mb-2">
                <div class="d-flex justify-space-between mb-1">
                    <MudText Typo="Typo.body2" Style="font-size:0.825rem">@app.Application</MudText>
                    <MudText Typo="Typo.body2" Style="font-size:0.825rem; font-weight:600">@app.Count.ToString("N0")</MudText>
                </div>
                <div style="height:6px; border-radius:3px; background:rgba(var(--mud-palette-primary-rgb),0.15)">
                    <div style="@($"height:100%; border-radius:3px; background:var(--mud-palette-primary); width:{pct:F1}%")"></div>
                </div>
            </div>
        }
    }
    else
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">No data in the last @Hours hours.</MudText>
    }
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Top Applications";
    [Parameter] public int Hours { get; set; } = 24;
    [Parameter] public int Limit { get; set; } = 10;

    private bool _loading = true;
    private List<AppCountDto>? _apps;

    protected override async Task OnInitializedAsync()
    {
        var now = DateTimeOffset.UtcNow;
        _apps = await Api.GetTopApplicationsAsync(now.AddHours(-Hours), now, Limit);
        _loading = false;
    }
}
