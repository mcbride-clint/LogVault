@inject ILogVaultApiClient Api
@inject IDialogService DialogService

<MudPaper Elevation="2" Class="pa-4 h-100" Style="border-radius:12px">
    <div class="d-flex justify-space-between align-center mb-3">
        <MudText Typo="Typo.subtitle1">@Title</MudText>
        <MudButton Href="/logs" Variant="Variant.Text" Color="Color.Primary"
                   EndIcon="@Icons.Material.Filled.ArrowForward" Size="Size.Small">
            View all
        </MudButton>
    </div>
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_errors?.Items.Count > 0)
    {
        <MudTable T="LogEventDto" Items="_errors.Items" Dense="true" Hover="true" Elevation="0"
                  Style="background:transparent"
                  OnRowClick="@((TableRowClickEventArgs<LogEventDto> args) => OnRowClick(args))"
                  RowStyle="cursor:pointer">
            <HeaderContent>
                <MudTh>Time</MudTh>
                <MudTh>Application</MudTh>
                <MudTh>Message</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd Style="white-space:nowrap; font-size:0.8rem">
                    @context.Timestamp.ToLocalTime().ToString("MM/dd HH:mm")
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                        @context.SourceApplication
                    </MudChip>
                </MudTd>
                <MudTd Style="font-size:0.825rem">@Truncate(context.RenderedMessage, 100)</MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <MudAlert Severity="Severity.Success" Dense="true" Variant="Variant.Text">
            No errors in the last @Hours hours.
        </MudAlert>
    }
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = "Recent Errors";
    [Parameter] public int Hours { get; set; } = 24;
    [Parameter] public int Limit { get; set; } = 20;

    private bool _loading = true;
    private PagedResult<LogEventDto>? _errors;

    protected override async Task OnInitializedAsync()
    {
        var now = DateTimeOffset.UtcNow;
        _errors = await Api.QueryLogsAsync(new LogQuery(
            From: now.AddHours(-Hours), Level: "Error", Page: 1, PageSize: Limit, Desc: true));
        _loading = false;
    }

    private async Task OnRowClick(TableRowClickEventArgs<LogEventDto> args)
    {
        var parameters = new DialogParameters<LogDetailDialog> { { x => x.Event, args.Item } };
        await DialogService.ShowAsync<LogDetailDialog>("Event Detail", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
    }

    private static string Truncate(string s, int max)
        => s.Length <= max ? s : s[..max] + "…";
}
