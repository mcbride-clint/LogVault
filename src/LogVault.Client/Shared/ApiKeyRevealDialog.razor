@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.VpnKey" Color="Color.Warning" />
            <MudText Typo="Typo.h6">@Title</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">
            Save this key now — it will <strong>not</strong> be shown again.
        </MudAlert>

        @if (!string.IsNullOrEmpty(Label))
        {
            <MudText Typo="Typo.body2" Class="mb-2"><strong>Label:</strong> @Label</MudText>
        }
        @if (!string.IsNullOrEmpty(OldKeyExpiry))
        {
            <MudText Typo="Typo.body2" Class="mb-2 mud-text-secondary">Old key expires: @OldKeyExpiry</MudText>
        }

        <MudTextField Value="@RawKey"
                      Label="API Key"
                      ReadOnly="true"
                      Variant="Variant.Outlined"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.ContentCopy"
                      AdornmentColor="Color.Primary"
                      OnAdornmentClick="CopyKey"
                      Style="font-family:monospace; font-size:0.85rem"
                      Class="mt-2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Primary" Variant="Variant.Filled">Done</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialog MudDialog { get; set; } = null!;

    [Parameter] public string Title { get; set; } = "API Key";
    [Parameter] public string RawKey { get; set; } = "";
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? OldKeyExpiry { get; set; }

    private async Task CopyKey()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", RawKey);
        Snackbar.Add("Key copied to clipboard", Severity.Success);
    }

    private void Close() => MudDialog.CloseAsync();
}
