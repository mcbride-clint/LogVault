@inject ILogVaultApiClient Api
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.AddAlert" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Create Alert from Event</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
            Pre-filled from the selected log event. Refine before saving.
        </MudText>

        <MudTextField @bind-Value="_name"
                      Label="Rule Name"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Label"
                      Required="true" />

        <MudSelect T="string" @bind-Value="_level"
                   Label="Minimum Level"
                   Variant="Variant.Outlined"
                   Class="mb-4"
                   Adornment="Adornment.Start"
                   AdornmentIcon="@Icons.Material.Filled.FilterList">
            <MudSelectItem Value='"Verbose"'>Verbose</MudSelectItem>
            <MudSelectItem Value='"Debug"'>Debug</MudSelectItem>
            <MudSelectItem Value='"Information"'>Information</MudSelectItem>
            <MudSelectItem Value='"Warning"'>Warning</MudSelectItem>
            <MudSelectItem Value='"Error"'>Error</MudSelectItem>
            <MudSelectItem Value='"Fatal"'>Fatal</MudSelectItem>
        </MudSelect>

        <MudTextField @bind-Value="_appFilter"
                      Label="Source Application Filter"
                      HelperText="Leave blank to match all applications"
                      Variant="Variant.Outlined"
                      Class="mb-4"
                      Clearable="true"
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Apps" />

        <MudTextField @bind-Value="_expr"
                      Label="Filter Expression"
                      Variant="Variant.Outlined"
                      Lines="3"
                      Class="mb-4"
                      HelperText='e.g. level >= Error AND app == "MyApp"' />

        <MudNumericField T="int" @bind-Value="_throttle"
                         Label="Throttle (minutes between emails)"
                         Variant="Variant.Outlined"
                         Min="1"
                         Class="mb-4"
                         Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.Timer" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-2">@_error</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="SaveAndEdit"
                   Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   Disabled="@_saving">
            Save &amp; Edit
        </MudButton>
        <MudButton OnClick="Save"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@(string.IsNullOrWhiteSpace(_name) || _saving)">
            @(_saving ? "Saving..." : "Save Alert")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter, EditorRequired] public LogEventDto Event { get; set; } = null!;

    private string _name = "";
    private string _level = "Error";
    private string _appFilter = "";
    private string _expr = "";
    private int _throttle = 60;
    private bool _saving;
    private string? _error;

    protected override void OnParametersSet()
    {
        _level = Event.Level ?? "Error";
        _appFilter = Event.SourceApplication ?? "";
        _expr = BuildExpression();
        _name = string.IsNullOrEmpty(_appFilter)
            ? $"{_level} alert"
            : $"{_appFilter} {_level} alert";
    }

    private string BuildExpression()
    {
        var parts = new List<string> { $"level >= {_level}" };
        if (!string.IsNullOrEmpty(Event.SourceApplication))
            parts.Add($"app == \"{Event.SourceApplication}\"");
        return string.Join(" AND ", parts);
    }

    private async Task Save()
    {
        _error = null;
        _saving = true;
        try
        {
            var request = new AlertRuleRequest(
                _name, _expr, _level,
                string.IsNullOrEmpty(_appFilter) ? null : _appFilter,
                _throttle, true, new List<string>());

            var result = await Api.CreateAlertAsync(request);
            if (result != null)
            {
                Snackbar.Add($"Alert \"{result.Name}\" created.", Severity.Success);
                MudDialog.Close(DialogResult.Ok(result));
            }
            else
            {
                _error = "Failed to create alert rule.";
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task SaveAndEdit()
    {
        _error = null;
        _saving = true;
        try
        {
            var request = new AlertRuleRequest(
                _name, _expr, _level,
                string.IsNullOrEmpty(_appFilter) ? null : _appFilter,
                _throttle, true, new List<string>());

            var result = await Api.CreateAlertAsync(request);
            if (result != null)
            {
                MudDialog.Close();
                Nav.NavigateTo($"/alerts/{result.Id}");
            }
            else
            {
                _error = "Failed to create alert rule.";
            }
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
