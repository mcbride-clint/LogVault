@inject AuthStateService Auth
@implements IDisposable

<MudNavMenu Color="Color.Primary" Bordered="false" Class="pa-2">
    <MudNavLink Href="dashboard" Match="NavLinkMatch.All"
                Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>
    <MudNavLink Href="logs"
                Icon="@Icons.Material.Filled.List">
        Log Explorer
    </MudNavLink>
    <MudNavLink Href="alerts"
                Icon="@Icons.Material.Filled.NotificationsActive">
        Alert Rules
    </MudNavLink>

    @if (Auth.IsAdmin)
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.overline" Class="px-4 pb-1" Style="color: rgba(255,255,255,0.45); font-size:0.65rem; letter-spacing:0.1em">
            ADMIN
        </MudText>
        <MudNavLink Href="admin/apikeys"
                    Icon="@Icons.Material.Filled.VpnKey">
            API Keys
        </MudNavLink>
        <MudNavLink Href="admin/purge"
                    Icon="@Icons.Material.Filled.DeleteSweep">
            Retention
        </MudNavLink>
    }
</MudNavMenu>

@code {
    protected override void OnInitialized() => Auth.OnChange += StateHasChanged;
    public void Dispose() => Auth.OnChange -= StateHasChanged;
}
