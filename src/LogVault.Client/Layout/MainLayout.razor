@inherits LayoutComponentBase
@inject AuthStateService Auth
@inject NavigationManager Nav
@inject ILogVaultApiClient Api
@inject ThemeService ThemeService
@implements IDisposable

<MudLayout>
    <MudAppBar Elevation="0" Dense="false" Color="Color.Inherit" Style="background: var(--mud-palette-appbar-background);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer"
                       Title="Toggle navigation" />
        <MudText Typo="Typo.h6" Class="ml-2 mud-text-secondary" Style="color: rgba(255,255,255,0.9); font-weight:700; letter-spacing:0.5px">
            Log<span style="color: var(--mud-palette-primary-lighten)">Vault</span>
        </MudText>
        <MudSpacer />
        @if (Auth.IsAuthenticated)
        {
            <MudText Typo="Typo.body2" Class="mr-3 d-none d-sm-flex align-center" Style="color: rgba(255,255,255,0.75)">
                @(Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.Username)
            </MudText>
            <MudTooltip Text="@(ThemeService.IsDarkMode ? "Switch to light mode" : "Switch to dark mode")">
                <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               OnClick="ThemeService.ToggleDarkMode" />
            </MudTooltip>
            <MudTooltip Text="Sign out">
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               OnClick="Logout" />
            </MudTooltip>
        }
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="0"
               Variant="DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md"
               ClipMode="DrawerClipMode.Never">
        <MudDrawerHeader Class="d-flex align-center pa-4" Style="background: var(--mud-palette-drawer-background)">
            <MudIcon Icon="@Icons.Material.Filled.Storage" Color="Color.Primary" Size="Size.Large" Class="mr-2" />
            <MudText Typo="Typo.h6" Style="color: rgba(255,255,255,0.9); font-weight:700">
                Log<span style="color: var(--mud-palette-primary-lighten)">Vault</span>
            </MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pt-16">
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 pa-md-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    protected override async Task OnInitializedAsync()
    {
        Auth.OnChange += StateHasChanged;
        ThemeService.OnChange += StateHasChanged;
        await Auth.InitializeAsync(Api);
        if (!Auth.IsAuthenticated && !Nav.Uri.Contains("/login"))
            Nav.NavigateTo("/login");
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task Logout()
    {
        await Api.LogoutAsync();
        Auth.SetUser(null);
        Nav.NavigateTo("/login");
    }

    public void Dispose()
    {
        Auth.OnChange -= StateHasChanged;
        ThemeService.OnChange -= StateHasChanged;
    }
}
