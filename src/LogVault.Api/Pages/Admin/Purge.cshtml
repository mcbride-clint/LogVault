@page
@model LogVault.Api.Pages.Admin.PurgeModel
@{
    ViewData["Title"] = "Retention & Purge";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Retention &amp; Purge</h4>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">Manual Purge</div>
            <div class="card-body">
                <p class="text-muted small">Delete all log events older than a specific date. This cannot be undone.</p>
                <form method="post" asp-page-handler="Purge">
                    <div class="mb-3">
                        <label class="form-label">Delete events older than</label>
                        <input type="datetime-local" asp-for="Before" class="form-control"
                               value="@(Model.Before?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm") ?? DateTime.Now.AddDays(-30).ToString("yyyy-MM-ddT00:00"))" />
                    </div>
                    <button type="submit" class="btn btn-danger"
                            onclick="return confirm('Are you sure? This will permanently delete log events.')">
                        Purge Events
                    </button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header">Trigger Retention Worker</div>
            <div class="card-body">
                <p class="text-muted small">Manually run the retention policy (respects configured retention days).</p>
                <button class="btn btn-outline-warning" id="btn-trigger-retention">Run Retention Now</button>
                <div id="retention-result" class="mt-2 text-muted small"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    document.getElementById('btn-trigger-retention').addEventListener('click', async function () {
        this.disabled = true;
        const resp = await lvFetch('/api/admin/logs/purge/trigger', { method: 'POST' });
        const res = document.getElementById('retention-result');
        if (resp.ok) {
            const j = await resp.json().catch(() => ({}));
            res.textContent = 'Retention triggered. Deleted: ' + (j.deleted ?? '—');
        } else {
            res.textContent = 'Failed: ' + resp.status;
        }
        this.disabled = false;
    });
    </script>
}
