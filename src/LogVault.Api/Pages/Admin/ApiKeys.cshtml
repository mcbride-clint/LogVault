@page
@model LogVault.Api.Pages.Admin.ApiKeysModel
@{
    ViewData["Title"] = "API Keys";
    var newRawKey = ViewData["NewRawKey"] as string;
    var newKeyLabel = ViewData["NewKeyLabel"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">API Keys</h4>
</div>

@if (newRawKey is not null)
{
    <div class="alert alert-warning alert-dismissible">
        <strong>Key created: @newKeyLabel</strong><br />
        Copy this key now — it will not be shown again.
        <div class="input-group mt-2">
            <input type="text" class="form-control font-monospace" id="new-raw-key" value="@newRawKey" readonly />
            <button class="btn btn-outline-secondary" onclick="lvCopy('new-raw-key', this)">Copy</button>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="table-responsive mb-4">
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Label</th>
                <th>Default App</th>
                <th>Created</th>
                <th>Expires</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var key in Model.Keys)
            {
                <tr>
                    <td>@key.Label</td>
                    <td class="small">@(key.DefaultApplication ?? "—")</td>
                    <td class="small">@key.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</td>
                    <td class="small">@(key.ExpiresAt?.ToLocalTime().ToString("yyyy-MM-dd") ?? "Never")</td>
                    <td>
                        @if (key.IsRevoked)
                        {
                            <span class="badge bg-danger">Revoked</span>
                        }
                        else if (key.IsExpired)
                        {
                            <span class="badge bg-warning text-dark">Expired</span>
                        }
                        else if (key.IsEnabled)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Disabled</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        @if (!key.IsRevoked)
                        {
                            <button class="btn btn-sm btn-outline-primary me-1"
                                    onclick="lvRotateKey(@key.Id, this)">Rotate</button>
                            <button class="btn btn-sm btn-outline-danger"
                                    onclick="lvRevokeKey(@key.Id, this)">Revoke</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<h5>Create New API Key</h5>
<form method="post" asp-page-handler="Create" class="row g-2 align-items-end" style="max-width:500px">
    <div class="col">
        <label class="form-label form-label-sm">Label</label>
        <input asp-for="NewLabel" class="form-control form-control-sm" placeholder="My Application" required />
    </div>
    <div class="col">
        <label class="form-label form-label-sm">Default App</label>
        <input asp-for="NewDefaultApp" class="form-control form-control-sm" placeholder="Optional" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary">Create</button>
    </div>
</form>

<!-- Rotate modal -->
<div class="modal fade" id="rotate-modal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Key</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Copy this key now — it will not be shown again.</p>
                <div class="input-group">
                    <input type="text" class="form-control font-monospace" id="rotate-raw-key" readonly />
                    <button class="btn btn-outline-secondary" onclick="lvCopy('rotate-raw-key', this)">Copy</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
    async function lvRevokeKey(id, btn) {
        if (!confirm('Revoke this API key?')) return;
        const resp = await lvFetch(`/api/admin/apikeys/${id}`, { method: 'DELETE' });
        if (resp.ok) location.reload();
        else alert('Revoke failed: ' + resp.status);
    }

    async function lvRotateKey(id, btn) {
        const resp = await lvFetch(`/api/admin/apikeys/${id}/rotate`, { method: 'POST' });
        if (!resp.ok) { alert('Rotate failed: ' + resp.status); return; }
        const json = await resp.json();
        document.getElementById('rotate-raw-key').value = json.rawKey ?? json.key ?? '';
        new bootstrap.Modal(document.getElementById('rotate-modal')).show();
    }
    </script>
}
