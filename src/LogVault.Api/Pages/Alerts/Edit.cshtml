@page "/alerts/{id:int?}"
@model LogVault.Api.Pages.Alerts.EditModel
@using LogVault.Domain.Entities
@{
    ViewData["Title"] = Model.EditId.HasValue ? "Edit Alert Rule" : "New Alert Rule";
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-page="/Alerts/Index" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="mb-0">@ViewData["Title"]</h4>
</div>

<div class="row">
    <div class="col-md-8">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>

            <div class="mb-3">
                <label class="form-label">Name</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Filter Expression</label>
                <div class="input-group">
                    <input asp-for="FilterExpression" class="form-control font-monospace" placeholder='level >= Error AND app = "MyApp"' />
                    <button type="button" class="btn btn-outline-secondary" id="btn-test-expr">Test</button>
                </div>
                <div id="expr-result" class="form-text"></div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-sm-6">
                    <label class="form-label">Minimum Level</label>
                    <select asp-for="MinimumLevel" class="form-select">
                        @foreach (var lv in Enum.GetValues<LogLevel>())
                        {
                            <option value="@lv">@lv</option>
                        }
                    </select>
                </div>
                <div class="col-sm-6">
                    <label class="form-label">Application Filter</label>
                    <input asp-for="SourceApplicationFilter" class="form-control" placeholder="Any application" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Throttle (minutes)</label>
                <input asp-for="ThrottleMinutes" type="number" min="1" class="form-control" style="max-width:140px" />
                <div class="form-text">Minimum minutes between repeat alerts for the same rule.</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Email Recipients</label>
                <div id="recipients-list">
                    @for (int i = 0; i < Math.Max(1, Model.Recipients.Count); i++)
                    {
                        <div class="input-group mb-1">
                            <input type="email" name="Recipients" class="form-control"
                                   value="@(i < Model.Recipients.Count ? Model.Recipients[i] : "")"
                                   placeholder="user@example.com" />
                            <button type="button" class="btn btn-outline-danger" onclick="this.closest('.input-group').remove()">×</button>
                        </div>
                    }
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary mt-1" onclick="lvAddRecipient()">+ Add recipient</button>
            </div>

            <div class="mb-3">
                <label class="form-label">Webhook URL</label>
                <input asp-for="WebhookUrl" type="url" class="form-control" placeholder="https://hooks.example.com/…" />
            </div>

            <div class="mb-3">
                <label class="form-label">Webhook Format</label>
                <select asp-for="WebhookFormat" class="form-select" style="max-width:200px">
                    @foreach (var f in Enum.GetValues<WebhookFormat>())
                    {
                        <option value="@f">@f</option>
                    }
                </select>
            </div>

            <div class="mb-4">
                <div class="form-check form-switch">
                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox" role="switch" />
                    <label asp-for="IsEnabled" class="form-check-label">Enabled</label>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Rule</button>
                <a asp-page="/Alerts/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
    function lvAddRecipient() {
        const div = document.createElement('div');
        div.className = 'input-group mb-1';
        div.innerHTML = '<input type="email" name="Recipients" class="form-control" placeholder="user@example.com" />' +
            '<button type="button" class="btn btn-outline-danger" onclick="this.closest(\'.input-group\').remove()">×</button>';
        document.getElementById('recipients-list').appendChild(div);
    }

    document.getElementById('btn-test-expr').addEventListener('click', async () => {
        const expr = document.querySelector('[name="FilterExpression"]').value;
        const res = document.getElementById('expr-result');
        if (!expr) { res.textContent = ''; return; }
        const resp = await lvFetch('/api/alerts/test', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ expression: expr })
        });
        const json = await resp.json().catch(() => ({}));
        res.textContent = resp.ok ? '✓ Valid expression' : ('Error: ' + (json.error ?? resp.status));
        res.className = 'form-text ' + (resp.ok ? 'text-success' : 'text-danger');
    });
    </script>
}
