@{
    var path = Context.Request.Path.Value ?? "";
}

<ul class="nav flex-column">
    <li class="nav-item">
        <a class="nav-link @(path == "/dashboard" ? "active" : "")" asp-page="/Dashboard">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                <path d="M0 1.5A1.5 1.5 0 0 1 1.5 0h2A1.5 1.5 0 0 1 5 1.5v2A1.5 1.5 0 0 1 3.5 5h-2A1.5 1.5 0 0 1 0 3.5v-2zm6.5 0A1.5 1.5 0 0 1 8 0h2A1.5 1.5 0 0 1 11.5 1.5v2A1.5 1.5 0 0 1 10 5H8A1.5 1.5 0 0 1 6.5 3.5v-2zm-6.5 6A1.5 1.5 0 0 1 1.5 6h2A1.5 1.5 0 0 1 5 7.5v2A1.5 1.5 0 0 1 3.5 11h-2A1.5 1.5 0 0 1 0 9.5v-2zm6.5 0A1.5 1.5 0 0 1 8 6h2A1.5 1.5 0 0 1 11.5 7.5v2A1.5 1.5 0 0 1 10 11H8A1.5 1.5 0 0 1 6.5 9.5v-2z"/>
            </svg>
            Dashboard
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(path.StartsWith("/logs") ? "active" : "")" asp-page="/Logs/Index">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                <path d="M14 4.5V14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V2a2 2 0 0 1 2-2h5.5L14 4.5zm-3 0A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V4.5h-2z"/>
            </svg>
            Log Explorer
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link @(path.StartsWith("/alerts") ? "active" : "")" asp-page="/Alerts/Index">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2zM8 1.918l-.797.161A4.002 4.002 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4.002 4.002 0 0 0-3.203-3.92L8 1.917zM14.22 12c.223.447.481.801.78 1H1c.299-.199.557-.553.78-1C2.68 10.2 3 6.88 3 6c0-2.42 1.72-4.44 4.005-4.901a1 1 0 1 1 1.99 0A5.002 5.002 0 0 1 13 6c0 .88.32 4.2 1.22 6z"/>
            </svg>
            Alert Rules
        </a>
    </li>
</ul>

@if (User.IsInRole("Admin"))
{
    <hr class="sidebar-divider" />
    <div class="sidebar-heading px-2 mb-1 text-uppercase small fw-bold opacity-50">Admin</div>
    <ul class="nav flex-column">
        <li class="nav-item">
            <a class="nav-link @(path.StartsWith("/admin/apikeys") ? "active" : "")" asp-page="/Admin/ApiKeys">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                    <path d="M0 8a4 4 0 0 1 7.465-2H14a.5.5 0 0 1 .354.146l1.5 1.5a.5.5 0 0 1 0 .708l-1.5 1.5a.5.5 0 0 1-.708 0L13 9.207l-.646.647a.5.5 0 0 1-.708 0L11 9.207l-.646.647a.5.5 0 0 1-.708 0L9 9.207l-.646.647A.5.5 0 0 1 8 10h-.535A4 4 0 0 1 0 8zm4-3a3 3 0 1 0 2.712 4.285A.5.5 0 0 1 7.163 9h.63l.853-.854a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.646-.647a.5.5 0 0 1 .708 0l.646.647.793-.793-1-1h-6.63a.5.5 0 0 1-.451-.285A3 3 0 0 0 4 5z"/>
                    <path d="M4 8a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                </svg>
                API Keys
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(path.StartsWith("/admin/purge") ? "active" : "")" asp-page="/Admin/Purge">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="me-2" viewBox="0 0 16 16">
                    <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5zm3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0V6z"/>
                    <path fill-rule="evenodd" d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1v1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4H4.118zM2.5 3V2h11v1h-11z"/>
                </svg>
                Retention
            </a>
        </li>
    </ul>
}
