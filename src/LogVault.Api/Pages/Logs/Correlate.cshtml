@page "/logs/correlate/{traceId}"
@model LogVault.Api.Pages.Logs.CorrelateModel
@using LogVault.Domain.Entities
@{
    ViewData["Title"] = $"Correlation — {Model.TraceId}";

    void RenderTable(IReadOnlyList<LogEvent> events, string heading)
    {
        <h6 class="mt-3">@heading (@events.Count)</h6>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead><tr><th>Timestamp</th><th>Level</th><th>Application</th><th>Message</th></tr></thead>
                <tbody>
                    @foreach (var ev in events)
                    {
                        <tr onclick="window.location='/logs/@ev.Id'" style="cursor:pointer">
                            <td class="text-nowrap small">@ev.Timestamp.ToLocalTime().ToString("HH:mm:ss.fff")</td>
                            <td><span class="badge @IndexModel.LevelBadgeClass(ev.Level)">@ev.Level</span></td>
                            <td class="small">@ev.SourceApplication</td>
                            <td class="small text-truncate" style="max-width:400px">@ev.RenderedMessage</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

<div class="d-flex align-items-center gap-2 mb-3">
    <a asp-page="/Logs/Index" class="btn btn-sm btn-outline-secondary">← Back</a>
    <h4 class="mb-0">Correlation</h4>
    <code class="small">@Model.TraceId</code>
</div>

@if (Model.TraceEvents.Count == 0)
{
    <p class="text-muted">No events found for trace ID <code>@Model.TraceId</code>.</p>
}
else
{
    RenderTable(Model.ContextBefore, "Context Before");
    RenderTable(Model.TraceEvents, "Trace Events");
    RenderTable(Model.ContextAfter, "Context After");
}
