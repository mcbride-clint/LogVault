@page
@model LogVault.Api.Pages.Logs.IndexModel
@using LogVault.Domain.Entities
@{
    ViewData["Title"] = "Log Explorer";
    int totalPages = (int)Math.Ceiling((double)Model.Result.TotalCount / Model.PageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Log Explorer</h4>
    <div class="d-flex gap-2 align-items-center">
        <span id="live-indicator" class="d-none">
            <span class="lv-live-dot"></span> Live
        </span>
        <button class="btn btn-sm btn-outline-secondary" id="btn-live-toggle">Start Live Tail</button>
        <a asp-page="/Logs/Index" class="btn btn-sm btn-outline-secondary">Clear</a>
    </div>
</div>

<form method="get" class="mb-3">
    <div class="row g-2">
        <div class="col-sm-6 col-md-3">
            <input type="text" class="form-control form-control-sm" name="q" value="@Model.Q" placeholder="Message contains…" />
        </div>
        <div class="col-sm-6 col-md-2">
            <select class="form-select form-select-sm" name="level">
                <option value="">All levels</option>
                @foreach (var lv in Enum.GetValues<LogLevel>())
                {
                    <option value="@lv" selected="@(Model.Level == lv.ToString())">@lv</option>
                }
            </select>
        </div>
        <div class="col-sm-6 col-md-2">
            <input type="text" class="form-control form-control-sm" name="app" value="@Model.App" placeholder="Application" />
        </div>
        <div class="col-sm-6 col-md-2">
            <input type="text" class="form-control form-control-sm" name="env" value="@Model.Env" placeholder="Environment" />
        </div>
        <div class="col-sm-6 col-md-2">
            <input type="text" class="form-control form-control-sm" name="traceId" value="@Model.TraceId" placeholder="Trace ID" />
        </div>
        <div class="col-sm-6 col-md-1">
            <button type="submit" class="btn btn-sm btn-primary w-100">Search</button>
        </div>
    </div>
    <div class="row g-2 mt-1">
        <div class="col-md-4">
            <input type="datetime-local" class="form-control form-control-sm" name="from"
                   value="@Model.From?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
        </div>
        <div class="col-md-4">
            <input type="datetime-local" class="form-control form-control-sm" name="to"
                   value="@Model.To?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
        </div>
        @if (Model.SavedFilters.Count > 0)
        {
            <div class="col-md-4">
                <select class="form-select form-select-sm" id="saved-filter-select" onchange="lvApplySavedFilter(this.value)">
                    <option value="">— Saved filters —</option>
                    @foreach (var sf in Model.SavedFilters)
                    {
                        <option value="@sf.FilterJson">@sf.Name</option>
                    }
                </select>
            </div>
        }
    </div>
    <input type="hidden" name="sort" value="@Model.Sort" />
    <input type="hidden" name="desc" value="@Model.Desc.ToString().ToLower()" />
    <input type="hidden" name="pageSize" value="@Model.PageSize" />
</form>

@if (Model.Result.TotalCount == 0)
{
    <p class="text-muted">No events match the current filter.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">@Model.Result.TotalCount.ToString("N0") events · page @Model.Page of @totalPages</small>
    </div>

    <div class="table-responsive">
        <table class="table table-sm table-hover lv-log-table mb-0">
            <thead>
                <tr>
                    <th style="width:160px">Timestamp</th>
                    <th style="width:90px">Level</th>
                    <th style="width:120px">Application</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody id="log-rows">
                @foreach (var ev in Model.Result.Items)
                {
                    <tr class="lv-log-row" onclick="window.location='/logs/@ev.Id'" style="cursor:pointer">
                        <td class="text-nowrap small">@ev.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td><span class="badge @IndexModel.LevelBadgeClass(ev.Level)">@ev.Level</span></td>
                        <td class="small text-truncate" style="max-width:120px">@ev.SourceApplication</td>
                        <td class="small text-truncate" style="max-width:500px">@ev.RenderedMessage</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-2">
            <ul class="pagination pagination-sm">
                @if (Model.Page > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Logs/Index" asp-all-route-data="Model.BuildPageRouteValues(Model.Page - 1)">«</a>
                    </li>
                }
                @for (int p = Math.Max(1, Model.Page - 2); p <= Math.Min(totalPages, Model.Page + 2); p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-page="/Logs/Index" asp-all-route-data="Model.BuildPageRouteValues(p)">@p</a>
                    </li>
                }
                @if (Model.Page < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-page="/Logs/Index" asp-all-route-data="Model.BuildPageRouteValues(Model.Page + 1)">»</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@section Scripts {
    <script src="/js/signalr.min.js"></script>
    <script src="/js/logs.js"></script>
}
