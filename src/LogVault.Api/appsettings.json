{
  "ConnectionStrings": {
    "Default": "Data Source=logvault.db"
  },
  "DatabaseProvider": "Sqlite",
  "ActiveDirectory": {
    "Server": "",
    "Port": 389,
    "UseSsl": false,
    "SearchBase": "DC=corp,DC=example,DC=com",
    "Domain": "CORP",
    "AdminGroup": "LogVault-Admins",
    "UserGroup": "LogVault-Users"
  },
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 25,
    "UseSsl": false,
    "FromAddress": "logvault@corp.example.com",
    "FromName": "LogVault Alerts"
  },
  "Ingestion": {
    "MaxBatchSize": 500,
    "ChannelCapacity": 1000,
    "FlushIntervalMs": 500
  },
  "Retention": {
    "AutoPurgeEnabled": false,
    "RetainDays": 90
  },
  "SignalR": {
    "LiveTailMaxEventsPerBroadcast": 100
  },
  "ApiKeys": {
    "RotationGraceHours": 24
  },
  "HealthChecks": {
    "LdapProbeTimeoutSeconds": 5,
    "SmtpProbeTimeoutSeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
