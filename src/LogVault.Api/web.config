<?xml version="1.0" encoding="utf-8"?>
<!--
  LogVault IIS Hosting Configuration
  ====================================
  Configures the ASP.NET Core Module for out-of-process (Kestrel) hosting behind IIS.

  Prerequisites:
    - .NET 8 Runtime or ASP.NET Core Hosting Bundle installed on the server
    - IIS feature "Application Development > ASP.NET Core Module v2" enabled

  Deployment:
    1. Publish the API project: dotnet publish -c Release -o ./publish
    2. Copy ./publish contents to the IIS site root (e.g., C:\inetpub\wwwroot\logvault)
    3. Create a new IIS Application Pool with:
         - .NET CLR version: No Managed Code
         - Managed Pipeline Mode: Integrated
    4. Assign the Application Pool to the site
    5. Ensure the Application Pool identity has Read+Execute on the site root
       and Read+Write on the SQLite database file location

  Configuration:
    Edit appsettings.json (or appsettings.Production.json) for production values.
    Never store secrets in web.config — use appsettings.Production.json or
    Windows environment variables / Secret Manager.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*"
             modules="AspNetCoreModuleV2"
             resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\LogVault.Api.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="outofprocess">
        <environmentVariables>
          <!-- Override any appsettings.json value via environment variables. -->
          <!-- Example: set the ASPNETCORE_ENVIRONMENT to Production -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>

      <!-- Restrict directory browsing -->
      <directoryBrowse enabled="false" />

      <!-- Security headers -->
      <httpProtocol>
        <customHeaders>
          <add name="X-Content-Type-Options" value="nosniff" />
          <add name="X-Frame-Options" value="DENY" />
          <add name="X-XSS-Protection" value="1; mode=block" />
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
